# App
NODE_ENV=development
PORT=3000
API_PREFIX=
CORS_ORIGIN=*
SWAGGER_ENABLED=true
SWAGGER_PATH=docs

# Database
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=noderax
# Set to true only for local development or controlled bootstrapping.
DB_SYNCHRONIZE=false
DB_LOGGING=false
DB_SSL=false

# Redis
REDIS_ENABLED=true
REDIS_URL=
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=noderax:

# Auth
JWT_SECRET=super-secret-jwt-key-change-me-in-production
JWT_EXPIRES_IN=1d
BCRYPT_SALT_ROUNDS=12

# Agents
AGENT_HEARTBEAT_TIMEOUT_SECONDS=90
AGENT_OFFLINE_CHECK_INTERVAL_SECONDS=30
AGENT_ENROLLMENT_TOKEN=change-me-agent-enrollment-token
AGENT_HIGH_CPU_THRESHOLD=90

# Bootstrap
# Set to true for an initial bootstrap only, then switch back to false.
SEED_DEFAULT_ADMIN=false
ADMIN_NAME=Noderax Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!
