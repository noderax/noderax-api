NODE_ENV=development
PORT=3000
API_PREFIX=
CORS_ORIGIN=*
SWAGGER_ENABLED=true
SWAGGER_PATH=docs

DB_HOST=127.0.0.1
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=noderax
