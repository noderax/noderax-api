# App
NODE_ENV=development
PORT=3000
CORS_ORIGIN=*
SWAGGER_ENABLED=true
SWAGGER_PATH=docs
# Optional but recommended for installer-managed deployments.
# Point this to a writable application-data directory, such as a mounted
# volume, persistent disk, or another writable path outside a read-only app
# filesystem.
NODERAX_STATE_DIR= "./.noderax"

# Database
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=noderax
# Set to true only for local development or controlled bootstrapping.
DB_SYNCHRONIZE=false
DB_LOGGING=false
DB_SSL=false

# Redis
REDIS_ENABLED=true
REDIS_URL=
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=noderax:

# Auth
JWT_SECRET=super-secret-jwt-key-change-me-in-production
JWT_EXPIRES_IN=1d
BCRYPT_SALT_ROUNDS=12

# Agents
# Mark a node offline if no heartbeat arrives within this many seconds.
AGENT_HEARTBEAT_TIMEOUT_SECONDS=90
# How often the background scheduler checks for stale online nodes.
AGENT_OFFLINE_CHECK_INTERVAL_SECONDS=30
# Realtime socket ping timeout before force-disconnect.
AGENT_REALTIME_PING_TIMEOUT_SECONDS=45
# How often realtime ping timeout checks run.
AGENT_REALTIME_PING_CHECK_INTERVAL_SECONDS=5
# How often stale task detector checks for stuck queued/running tasks.
AGENT_STALE_TASK_CHECK_INTERVAL_SECONDS=15
# Mark queued tasks as failed after this many seconds.
AGENT_STALE_QUEUED_TASK_TIMEOUT_SECONDS=120
# Mark running tasks as failed after this many seconds.
AGENT_STALE_RUNNING_TASK_TIMEOUT_SECONDS=1800
# Shared secret required only for the legacy single-step /agent/register flow.
AGENT_ENROLLMENT_TOKEN=change-me-agent-enrollment-token
AGENT_HIGH_CPU_THRESHOLD=90

# Bootstrap
# Set to true for an initial bootstrap only, then switch back to false.
SEED_DEFAULT_ADMIN=false
ADMIN_NAME=Noderax Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!

# Mail (Configure these for password reset emails and other notifications)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USERNAME=your-smtp-user
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_FROM_NAME=Noderax
WEB_APP_URL=http://localhost:3001